{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Number of fires by month, grouped by fire type. Click a series in the legend to isolate it. Source: Historical Bushfire Boundaries v2.0 (Digital Atlas of Australia).",
  "title": {
    "text": "When fires happen",
    "subtitle": "Two seasonal rhythms side by side",
    "anchor": "start",
    "offset": 12,
    "fontSize": 21,
    "fontWeight": 700,
    "color": "#211c19",
    "font": "Spectral, Georgia, serif",
    "subtitleFontSize": 13,
    "subtitleColor": "#6b625a",
    "subtitleFont": "Inter, system-ui, sans-serif",
    "subtitleFontWeight": 500
  },
  "width": "container",
  "height": 460,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "font": "Inter, system-ui, sans-serif",
    "padding": 10,
    "axis": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 8,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "legend": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "symbolSize": 110
    },
    "view": {
      "stroke": null
    }
  },
  "layer": [
    {
      "data": {
        "url": "data/hist_month_type.csv"
      },
      "params": [
        {
          "name": "fireSel",
          "select": {
            "type": "point",
            "fields": [
              "fire_type"
            ]
          },
          "bind": "legend"
        }
      ],
      "mark": {
        "type": "bar"
      },
      "encoding": {
        "x": {
          "field": "month",
          "type": "nominal",
          "title": null,
          "sort": [
            "Jan",
            "Feb",
            "Mar",
            "Apr",
            "May",
            "Jun",
            "Jul",
            "Aug",
            "Sep",
            "Oct",
            "Nov",
            "Dec"
          ],
          "axis": {
            "labelAngle": 0,
            "labelFontSize": 13
          }
        },
        "xOffset": {
          "field": "fire_type"
        },
        "y": {
          "field": "n_fires",
          "type": "quantitative",
          "title": "Number of fires",
          "scale": {
            "domain": [
              0,
              38000
            ]
          }
        },
        "color": {
          "field": "fire_type",
          "type": "nominal",
          "title": "Fire type",
          "scale": {
            "domain": [
              "Bushfire",
              "Prescribed Burn"
            ],
            "range": [
              "#b34700",
              "#5b8c5a"
            ]
          },
          "legend": {
            "orient": "none",
            "legendX": {
              "signal": "width - 240"
            },
            "legendY": -56,
            "direction": "horizontal",
            "title": null,
            "fillColor": "#ffffff",
            "strokeColor": "#e4dccf",
            "padding": 11,
            "cornerRadius": 8,
            "labelFontSize": 13,
            "symbolSize": 140,
            "symbolStrokeWidth": 0
          }
        },
        "opacity": {
          "condition": {
            "param": "fireSel",
            "value": 1
          },
          "value": 0.2
        },
        "tooltip": [
          {
            "field": "month",
            "type": "nominal",
            "title": "Month"
          },
          {
            "field": "fire_type",
            "type": "nominal",
            "title": "Type"
          },
          {
            "field": "n_fires",
            "type": "quantitative",
            "title": "Fires"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "month": "Jan",
            "fire_type": "Bushfire",
            "n_fires": 5247,
            "n_label": 14000,
            "label": "Bushfire peak"
          },
          {
            "month": "Apr",
            "fire_type": "Prescribed Burn",
            "n_fires": 30250,
            "n_label": 34500,
            "label": "Planned-burn peak"
          }
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#5a2600",
        "strokeWidth": 1,
        "strokeDash": [
          3,
          3
        ]
      },
      "encoding": {
        "x": {
          "field": "month",
          "type": "nominal",
          "sort": [
            "Jan",
            "Feb",
            "Mar",
            "Apr",
            "May",
            "Jun",
            "Jul",
            "Aug",
            "Sep",
            "Oct",
            "Nov",
            "Dec"
          ]
        },
        "xOffset": {
          "field": "fire_type",
          "type": "nominal",
          "scale": {
            "domain": [
              "Bushfire",
              "Prescribed Burn"
            ]
          }
        },
        "y": {
          "field": "n_fires",
          "type": "quantitative"
        },
        "y2": {
          "field": "n_label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "month": "Jan",
            "fire_type": "Bushfire",
            "n_label": 14000,
            "label": "Bushfire peak"
          },
          {
            "month": "Apr",
            "fire_type": "Prescribed Burn",
            "n_label": 34500,
            "label": "Planned-burn peak"
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Inter, system-ui, sans-serif",
        "fontStyle": "italic",
        "fontWeight": 700,
        "fontSize": 14,
        "color": "#3d1900",
        "dy": -8,
        "align": "left",
        "dx": 0
      },
      "encoding": {
        "x": {
          "field": "month",
          "type": "nominal",
          "sort": [
            "Jan",
            "Feb",
            "Mar",
            "Apr",
            "May",
            "Jun",
            "Jul",
            "Aug",
            "Sep",
            "Oct",
            "Nov",
            "Dec"
          ]
        },
        "xOffset": {
          "field": "fire_type",
          "type": "nominal",
          "scale": {
            "domain": [
              "Bushfire",
              "Prescribed Burn"
            ]
          }
        },
        "y": {
          "field": "n_label",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ]
}