{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Number of fires by month, grouped by fire type. Click a series in the legend to isolate it. Source: Historical Bushfire Boundaries v2.0 (Digital Atlas of Australia).",
  "title": {
    "text": "When fires happen",
    "subtitle": "Two seasonal rhythms side by side",
    "anchor": "start",
    "offset": 14,
    "fontSize": 26,
    "fontWeight": 700,
    "color": "#211c19",
    "font": "Fraunces, Georgia, serif",
    "subtitleFontSize": 19,
    "subtitleColor": "#6b625a",
    "subtitleFont": "Inter, system-ui, sans-serif",
    "subtitleFontStyle": "italic"
  },
  "width": "container",
  "height": 340,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "font": "Inter, system-ui, sans-serif",
    "padding": 10,
    "axis": {
      "labelFontSize": 17,
      "titleFontSize": 18,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 12,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "legend": {
      "labelFontSize": 17,
      "titleFontSize": 18,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "symbolSize": 140
    },
    "view": {
      "stroke": null
    }
  },
  "layer": [
    {
      "data": {
        "url": "data/hist_month_type.csv"
      },
      "params": [
        {
          "name": "fireSel",
          "select": {
            "type": "point",
            "fields": [
              "fire_type"
            ]
          },
          "bind": "legend"
        }
      ],
      "mark": {
        "type": "bar"
      },
      "encoding": {
        "x": {
          "field": "month",
          "type": "nominal",
          "title": null,
          "sort": [
            "Jan",
            "Feb",
            "Mar",
            "Apr",
            "May",
            "Jun",
            "Jul",
            "Aug",
            "Sep",
            "Oct",
            "Nov",
            "Dec"
          ],
          "axis": {
            "labelAngle": 0,
            "labelFontSize": 15
          }
        },
        "xOffset": {
          "field": "fire_type"
        },
        "y": {
          "field": "n_fires",
          "type": "quantitative",
          "title": "Number of fires"
        },
        "color": {
          "field": "fire_type",
          "type": "nominal",
          "title": "Fire type",
          "scale": {
            "domain": [
              "Bushfire",
              "Prescribed Burn"
            ],
            "range": [
              "#b34700",
              "#5b8c5a"
            ]
          }
        },
        "opacity": {
          "condition": {
            "param": "fireSel",
            "value": 1
          },
          "value": 0.2
        },
        "tooltip": [
          {
            "field": "month",
            "type": "nominal",
            "title": "Month"
          },
          {
            "field": "fire_type",
            "type": "nominal",
            "title": "Type"
          },
          {
            "field": "n_fires",
            "type": "quantitative",
            "title": "Fires"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "month": "Jan",
            "n_fires": 10500,
            "label": "Bushfire peak"
          },
          {
            "month": "Apr",
            "n_fires": 30100,
            "label": "Planned-burn peak"
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Fraunces, Georgia, serif",
        "fontStyle": "italic",
        "fontWeight": 600,
        "fontSize": 15,
        "color": "#5a2600",
        "dy": -12,
        "align": "center"
      },
      "encoding": {
        "x": {
          "field": "month",
          "type": "nominal",
          "sort": [
            "Jan",
            "Feb",
            "Mar",
            "Apr",
            "May",
            "Jun",
            "Jul",
            "Aug",
            "Sep",
            "Oct",
            "Nov",
            "Dec"
          ]
        },
        "y": {
          "field": "n_fires",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ]
}