{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Number of fires by month, grouped by fire type. Shows bushfires peak in summer while prescribed burns peak in autumn and spring. Source: Historical Bushfire Boundaries v2.0 (Digital Atlas of Australia).",
  "title": {
    "text": "When fires happen",
    "subtitle": "Bushfires peak in summer; planned burns in autumn and spring",
    "anchor": "start",
    "fontSize": 19,
    "subtitleColor": "#6b625a",
    "subtitleFontSize": 14,
    "font": "Source Serif 4, Georgia, serif",
    "fontWeight": 600,
    "color": "#211c19",
    "subtitleFont": "Source Sans 3, sans-serif",
    "subtitleFontStyle": "italic",
    "offset": 10
  },
  "width": "container",
  "height": 300,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "font": "Source Sans 3, sans-serif",
    "padding": 5,
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 13,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 8,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "legend": {
      "labelFontSize": 12,
      "titleFontSize": 13,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "symbolSize": 80
    },
    "view": {
      "stroke": null
    }
  },
  "data": {
    "url": "data/hist_month_type.csv"
  },
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "month",
      "type": "nominal",
      "title": null,
      "sort": [
        "Jan",
        "Feb",
        "Mar",
        "Apr",
        "May",
        "Jun",
        "Jul",
        "Aug",
        "Sep",
        "Oct",
        "Nov",
        "Dec"
      ],
      "axis": {
        "labelAngle": 0
      }
    },
    "xOffset": {
      "field": "fire_type"
    },
    "y": {
      "field": "n_fires",
      "type": "quantitative",
      "title": "Number of fires"
    },
    "color": {
      "field": "fire_type",
      "type": "nominal",
      "title": "Fire type",
      "scale": {
        "domain": [
          "Bushfire",
          "Prescribed Burn"
        ],
        "range": [
          "#b34700",
          "#5b8c5a"
        ]
      }
    },
    "tooltip": [
      {
        "field": "month",
        "type": "nominal",
        "title": "Month"
      },
      {
        "field": "fire_type",
        "type": "nominal",
        "title": "Type"
      },
      {
        "field": "n_fires",
        "type": "quantitative",
        "title": "Fires"
      }
    ]
  }
}