{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Choropleth of bushfire at-risk education facilities per Victorian local government area, combining the BARR register with ABS LGA boundaries. Uses an equal-area projection so colour can be compared fairly across areas of different size.",
  "title": {
    "text": "Where Victoria's at-risk schools are",
    "subtitle": "Bushfire at-risk education facilities by local government area, 2025\u201326",
    "anchor": "start",
    "fontSize": 32,
    "subtitleColor": "#6b625a",
    "subtitleFontSize": 19,
    "font": "Newsreader, Source Serif 4, Georgia, serif",
    "fontWeight": 700,
    "color": "#211c19",
    "subtitleFont": "Source Sans 3, sans-serif",
    "subtitleFontStyle": "italic",
    "offset": 14
  },
  "width": "container",
  "height": 540,
  "config": {
    "font": "Source Sans 3, sans-serif",
    "view": {
      "stroke": null
    },
    "padding": 10,
    "axis": {
      "labelFontSize": 15,
      "titleFontSize": 16,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 12,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "legend": {
      "labelFontSize": 15,
      "titleFontSize": 16,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "symbolSize": 120
    }
  },
  "projection": {
    "type": "conicEqualArea",
    "center": [
      0,
      -36.5
    ],
    "rotate": [
      -145,
      0,
      0
    ],
    "parallels": [
      -36,
      -38
    ]
  },
  "data": {
    "url": "data/LGA_VIC.geojson",
    "format": {
      "type": "json",
      "property": "features"
    }
  },
  "transform": [
    {
      "lookup": "properties.lga_name",
      "from": {
        "data": {
          "url": "data/barr_by_lga.csv"
        },
        "key": "lga_name",
        "fields": [
          "n"
        ]
      }
    },
    {
      "calculate": "isValid(datum.n) ? datum.n : 0",
      "as": "facilities"
    }
  ],
  "params": [
    {
      "name": "hover",
      "select": {
        "type": "point",
        "on": "pointerover",
        "clear": "pointerout",
        "fields": [
          "properties.lga_name"
        ]
      }
    }
  ],
  "mark": {
    "type": "geoshape"
  },
  "encoding": {
    "color": {
      "field": "facilities",
      "type": "quantitative",
      "title": "At-risk facilities",
      "scale": {
        "scheme": "yelloworangered"
      },
      "legend": {
        "orient": "top",
        "direction": "horizontal",
        "gradientLength": 200,
        "titleColor": "#241f1c",
        "labelColor": "#241f1c",
        "titleFontSize": 11,
        "labelFontSize": 10
      }
    },
    "stroke": {
      "condition": {
        "param": "hover",
        "empty": false,
        "value": "#2b2b2b"
      },
      "value": "white"
    },
    "strokeWidth": {
      "condition": {
        "param": "hover",
        "empty": false,
        "value": 2
      },
      "value": 0.5
    },
    "tooltip": [
      {
        "field": "properties.lga_name",
        "type": "nominal",
        "title": "LGA"
      },
      {
        "field": "facilities",
        "type": "quantitative",
        "title": "At-risk facilities"
      }
    ]
  }
}