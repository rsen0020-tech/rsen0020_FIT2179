{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Top 15 local government areas by number of at-risk education facilities. Source: BARR register (data.vic.gov.au).",
  "title": {"text": "Top 15 LGAs by at-risk facilities", "anchor": "start", "fontSize": 15},
  "width": "container",
  "height": 380,
  "autosize": {"type": "fit", "contains": "padding"},
  "config": {"font": "Source Sans 3, sans-serif"},
  "data": {"url": "data/barr_by_lga.csv"},
  "transform": [
    {"window": [{"op": "rank", "as": "rank"}], "sort": [{"field": "n", "order": "descending"}]},
    {"filter": "datum.rank <= 15"}
  ],
  "mark": {"type": "bar", "color": "#b34700"},
  "encoding": {
    "y": {"field": "lga_name", "type": "nominal", "title": null, "sort": "-x"},
    "x": {"field": "n", "type": "quantitative", "title": "At-risk facilities"},
    "tooltip": [{"field": "lga_name", "type": "nominal", "title": "LGA"}, {"field": "n", "type": "quantitative", "title": "Facilities"}]
  }
}
