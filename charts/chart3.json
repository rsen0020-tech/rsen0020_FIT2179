{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Top 15 local government areas by number of at-risk education facilities, with Yarra Ranges highlighted. Source: BARR register (data.vic.gov.au).",
  "title": {
    "text": "Top 15 LGAs by at-risk facilities",
    "anchor": "start",
    "fontSize": 26,
    "font": "Newsreader, Source Serif 4, Georgia, serif",
    "fontWeight": 700,
    "color": "#211c19",
    "offset": 14
  },
  "width": "container",
  "height": 380,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "font": "Source Sans 3, sans-serif",
    "padding": 10,
    "axis": {
      "labelFontSize": 15,
      "titleFontSize": 16,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 12,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "legend": {
      "labelFontSize": 15,
      "titleFontSize": 16,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "symbolSize": 120
    },
    "view": {
      "stroke": null
    }
  },
  "layer": [
    {
      "data": {
        "url": "data/barr_by_lga.csv"
      },
      "transform": [
        {
          "window": [
            {
              "op": "rank",
              "as": "rank"
            }
          ],
          "sort": [
            {
              "field": "n",
              "order": "descending"
            }
          ]
        },
        {
          "filter": "datum.rank <= 15"
        }
      ],
      "params": [
        {
          "name": "hover",
          "select": {
            "type": "point",
            "on": "pointerover",
            "clear": "pointerout"
          }
        }
      ],
      "mark": {
        "type": "bar",
        "color": "#b34700"
      },
      "encoding": {
        "y": {
          "field": "lga_name",
          "type": "nominal",
          "title": null,
          "sort": [
            "Yarra Ranges",
            "Greater Bendigo",
            "Nillumbik",
            "Mornington Peninsula",
            "Macedon Ranges",
            "East Gippsland",
            "Mount Alexander",
            "Cardinia",
            "Manningham",
            "Indigo",
            "Alpine",
            "Ballarat",
            "Murrindindi",
            "Hepburn",
            "Surf Coast"
          ]
        },
        "x": {
          "field": "n",
          "type": "quantitative",
          "title": "At-risk facilities"
        },
        "fillOpacity": {
          "condition": {
            "param": "hover",
            "empty": false,
            "value": 1
          },
          "value": 0.85
        },
        "tooltip": [
          {
            "field": "lga_name",
            "type": "nominal",
            "title": "LGA"
          },
          {
            "field": "n",
            "type": "quantitative",
            "title": "Facilities"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "lga_name": "Yarra Ranges",
            "n": 156,
            "note": "Twice any other shire"
          }
        ]
      },
      "mark": {
        "type": "text",
        "color": "#fff",
        "fontWeight": "bold",
        "align": "right",
        "dx": -8,
        "fontSize": 13
      },
      "encoding": {
        "y": {
          "field": "lga_name",
          "type": "nominal",
          "sort": [
            "Yarra Ranges",
            "Greater Bendigo",
            "Nillumbik",
            "Mornington Peninsula",
            "Macedon Ranges",
            "East Gippsland",
            "Mount Alexander",
            "Cardinia",
            "Manningham",
            "Indigo",
            "Alpine",
            "Ballarat",
            "Murrindindi",
            "Hepburn",
            "Surf Coast"
          ]
        },
        "x": {
          "field": "n",
          "type": "quantitative"
        },
        "text": {
          "field": "note",
          "type": "nominal"
        }
      }
    }
  ]
}