{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Top 15 local government areas by number of at-risk education facilities, with Yarra Ranges highlighted. A checkbox switches between a capped 0-80 view (so the pack is readable) and the full 0-160 scale that shows Yarra Ranges' true count of 156. Source: BARR register (data.vic.gov.au).",
  "title": {
    "text": "Top 15 LGAs by at-risk facilities",
    "subtitle": "Tick the box to expand the scale and reveal Yarra Ranges' full 156",
    "anchor": "start",
    "fontSize": 21,
    "subtitleFontSize": 13,
    "subtitleColor": "#6b625a",
    "subtitleFont": "Inter, system-ui, sans-serif",
    "subtitleFontWeight": 500,
    "font": "Spectral, Georgia, serif",
    "fontWeight": 700,
    "color": "#211c19",
    "offset": 12
  },
  "width": "container",
  "height": 380,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "font": "Inter, system-ui, sans-serif",
    "padding": 10,
    "axis": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 8,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "view": {"stroke": null}
  },
  "params": [
    {
      "name": "showFull",
      "value": false,
      "bind": {
        "input": "checkbox",
        "name": "Show Yarra Ranges at full length (156)   "
      }
    }
  ],
  "encoding": {
    "y": {
      "field": "lga_name",
      "type": "nominal",
      "title": null,
      "sort": [
        "Yarra Ranges",
        "Greater Bendigo",
        "Nillumbik",
        "Mornington Peninsula",
        "Macedon Ranges",
        "East Gippsland",
        "Mount Alexander",
        "Cardinia",
        "Manningham",
        "Indigo",
        "Alpine",
        "Ballarat",
        "Hepburn",
        "Murrindindi",
        "Surf Coast"
      ]
    },
    "x": {
      "field": "n",
      "type": "quantitative",
      "title": "At-risk facilities",
      "scale": {
        "domainMin": 0,
        "domainMax": {"expr": "showFull ? 160 : 80"},
        "clamp": true
      },
      "axis": {"tickCount": 5}
    }
  },
  "layer": [
    {
      "data": {"url": "data/barr_by_lga.csv"},
      "transform": [
        {
          "filter": {
            "field": "lga_name",
            "oneOf": [
              "Yarra Ranges",
              "Greater Bendigo",
              "Nillumbik",
              "Mornington Peninsula",
              "Macedon Ranges",
              "East Gippsland",
              "Mount Alexander",
              "Cardinia",
              "Manningham",
              "Indigo",
              "Alpine",
              "Ballarat",
              "Hepburn",
              "Murrindindi",
              "Surf Coast"
            ]
          }
        }
      ],
      "params": [
        {
          "name": "hover",
          "select": {
            "type": "point",
            "on": "pointerover",
            "clear": "pointerout"
          }
        }
      ],
      "mark": {"type": "bar", "color": "#b34700"},
      "encoding": {
        "fillOpacity": {
          "condition": {"param": "hover", "empty": false, "value": 1},
          "value": 0.85
        },
        "tooltip": [
          {"field": "lga_name", "type": "nominal", "title": "LGA"},
          {"field": "n", "type": "quantitative", "title": "Facilities"}
        ]
      }
    },
    {
      "data": {
        "values": [
          {"lga_name": "Yarra Ranges", "n": 156, "note": "156 — over twice any other LGA"}
        ]
      },
      "mark": {
        "type": "text",
        "color": "#fff",
        "font": "Inter, system-ui, sans-serif",
        "fontStyle": "italic",
        "fontWeight": 700,
        "align": "right",
        "dx": -10,
        "fontSize": 14
      },
      "encoding": {
        "text": {"field": "note", "type": "nominal"}
      }
    }
  ]
}
