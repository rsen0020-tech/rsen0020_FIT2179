{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Area burnt in Victoria each year by fire type, with major fire seasons labelled. Click a series in the legend to isolate it. Source: Historical Bushfire Boundaries v2.0.",
  "title": {
    "text": "Area burnt in Victoria each year",
    "subtitle": "Click 'Bushfire' or 'Prescribed Burn' in the legend to isolate a series",
    "anchor": "start",
    "offset": 14,
    "fontSize": 26,
    "fontWeight": 700,
    "color": "#211c19",
    "font": "Newsreader, Source Serif 4, Georgia, serif",
    "subtitleFontSize": 19,
    "subtitleColor": "#6b625a",
    "subtitleFont": "Source Sans 3, sans-serif",
    "subtitleFontStyle": "italic"
  },
  "width": "container",
  "height": 380,
  "config": {
    "font": "Source Sans 3, sans-serif",
    "padding": 10,
    "axis": {
      "labelFontSize": 17,
      "titleFontSize": 18,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 12,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "legend": {
      "labelFontSize": 17,
      "titleFontSize": 18,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "symbolSize": 140
    },
    "view": {
      "stroke": null
    }
  },
  "layer": [
    {
      "data": {
        "url": "data/hist_year_type.csv"
      },
      "mark": {
        "type": "line",
        "point": {
          "size": 18
        },
        "strokeWidth": 2
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "title": null,
          "axis": {
            "format": "d"
          },
          "scale": {
            "domain": [
              1950,
              2024
            ]
          }
        },
        "y": {
          "field": "area_ha",
          "type": "quantitative",
          "title": "Area burnt (ha)",
          "scale": {
            "domain": [
              0,
              6000000
            ]
          }
        },
        "color": {
          "field": "fire_type",
          "type": "nominal",
          "title": "Fire type",
          "scale": {
            "domain": [
              "Bushfire",
              "Prescribed Burn"
            ],
            "range": [
              "#b34700",
              "#5b8c5a"
            ]
          }
        },
        "opacity": {
          "condition": {
            "param": "fireSel",
            "value": 1
          },
          "value": 0.18
        },
        "tooltip": [
          {
            "field": "year",
            "type": "quantitative",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "fire_type",
            "type": "nominal",
            "title": "Type"
          },
          {
            "field": "area_ha",
            "type": "quantitative",
            "title": "Area (ha)",
            "format": ","
          }
        ]
      },
      "params": [
        {
          "name": "fireSel",
          "select": {
            "type": "point",
            "fields": [
              "fire_type"
            ]
          },
          "bind": "legend"
        }
      ]
    },
    {
      "data": {
        "values": [
          {
            "year": 2003,
            "area_ha": 5406777,
            "label": "2003 alpine fires"
          },
          {
            "year": 2019,
            "area_ha": 3314826,
            "label": "Black Summer (2019\u201320)"
          },
          {
            "year": 2009,
            "area_ha": 2052579,
            "label": "Black Saturday (2009)"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -10,
        "dy": -4,
        "fontWeight": "bold",
        "fontSize": 12,
        "color": "#5a2600"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "scale": {
            "domain": [
              1950,
              2024
            ]
          }
        },
        "y": {
          "field": "area_ha",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ]
}