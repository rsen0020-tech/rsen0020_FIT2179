{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Area burnt in Victoria each year by fire type, with major fire seasons labelled. Click a series in the legend to isolate it. Source: Historical Bushfire Boundaries v2.0.",
  "title": {
    "text": "Area burnt in Victoria each year",
    "subtitle": "Click 'Bushfire' or 'Prescribed Burn' in the legend to isolate a series",
    "anchor": "start",
    "offset": 12,
    "fontSize": 21,
    "fontWeight": 700,
    "color": "#211c19",
    "font": "Plus Jakarta Sans, Inter, system-ui, sans-serif",
    "subtitleFontSize": 13,
    "subtitleColor": "#6b625a",
    "subtitleFont": "Inter, system-ui, sans-serif",
    "subtitleFontWeight": 500
  },
  "width": "container",
  "height": 400,
  "config": {
    "font": "Inter, system-ui, sans-serif",
    "padding": 10,
    "axis": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 8,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "legend": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "symbolSize": 110
    },
    "view": {
      "stroke": null
    }
  },
  "layer": [
    {
      "data": {
        "url": "data/hist_year_type.csv"
      },
      "mark": {
        "type": "line",
        "point": {
          "size": 18
        },
        "strokeWidth": 2
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "title": null,
          "axis": {
            "format": "d"
          },
          "scale": {
            "domain": [
              1950,
              2024
            ]
          }
        },
        "y": {
          "field": "area_ha",
          "type": "quantitative",
          "title": "Area burnt (ha)",
          "scale": {
            "domain": [
              0,
              7000000
            ]
          }
        },
        "color": {
          "field": "fire_type",
          "type": "nominal",
          "title": "Fire type",
          "scale": {
            "domain": [
              "Bushfire",
              "Prescribed Burn"
            ],
            "range": [
              "#b34700",
              "#5b8c5a"
            ]
          },
          "legend": {
            "orient": "top-right",
            "direction": "vertical",
            "fillColor": "#ffffff",
            "strokeColor": "#e4dccf",
            "padding": 10,
            "cornerRadius": 6,
            "offset": 8,
            "labelFontSize": 12,
            "titleFontSize": 12
          }
        },
        "opacity": {
          "condition": {
            "param": "fireSel",
            "value": 1
          },
          "value": 0.18
        },
        "tooltip": [
          {
            "field": "year",
            "type": "quantitative",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "fire_type",
            "type": "nominal",
            "title": "Type"
          },
          {
            "field": "area_ha",
            "type": "quantitative",
            "title": "Area (ha)",
            "format": ","
          }
        ]
      },
      "params": [
        {
          "name": "fireSel",
          "select": {
            "type": "point",
            "fields": [
              "fire_type"
            ]
          },
          "bind": "legend"
        }
      ]
    },
    {
      "data": {
        "values": [
          {
            "year": 2003,
            "area_ha": 5406777,
            "area_label": 6700000,
            "label": "2003 alpine fires"
          },
          {
            "year": 2009,
            "area_ha": 2052579,
            "area_label": 6100000,
            "label": "Black Saturday (2009)"
          },
          {
            "year": 2019,
            "area_ha": 3314826,
            "area_label": 5500000,
            "label": "Black Summer (2019–20)"
          }
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#5a2600",
        "strokeWidth": 1,
        "strokeDash": [
          3,
          3
        ]
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "scale": {
            "domain": [
              1950,
              2024
            ]
          }
        },
        "y": {
          "field": "area_ha",
          "type": "quantitative"
        },
        "y2": {
          "field": "area_label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "year": 2003,
            "area_label": 6700000,
            "label": "2003 alpine fires"
          },
          {
            "year": 2009,
            "area_label": 6100000,
            "label": "Black Saturday (2009)"
          },
          {
            "year": 2019,
            "area_label": 5500000,
            "label": "Black Summer (2019–20)"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "center",
        "dy": -8,
        "font": "Inter, system-ui, sans-serif",
        "fontStyle": "italic",
        "fontWeight": 700,
        "fontSize": 14,
        "color": "#3d1900"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "scale": {
            "domain": [
              1950,
              2024
            ]
          }
        },
        "y": {
          "field": "area_label",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ]
}