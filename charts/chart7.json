{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Area burnt in Victoria each year, split by fire type. Source: Historical Bushfire Boundaries v2.0 (Digital Atlas of Australia). Area is the sum of recorded fire footprints and may include overlaps.",
  "title": {"text": "Area burnt in Victoria each year", "subtitle": "Sum of recorded fire footprints (hectares), 1950–2023", "anchor": "start", "fontSize": 15, "subtitleColor": "#6b6b6b", "subtitleFontSize": 11},
  "width": "container",
  "height": 300,
  "autosize": {"type": "fit", "contains": "padding"},
  "config": {"font": "Source Sans 3, sans-serif"},
  "data": {"url": "data/hist_year_type.csv"},
  "mark": {"type": "line", "point": {"size": 18}},
  "encoding": {
    "x": {"field": "year", "type": "quantitative", "title": null, "axis": {"format": "d"}, "scale": {"domain": [1950, 2024]}},
    "y": {"field": "area_ha", "type": "quantitative", "title": "Area burnt (ha)"},
    "color": {"field": "fire_type", "type": "nominal", "title": "Fire type", "scale": {"domain": ["Bushfire", "Prescribed Burn"], "range": ["#b34700", "#5b8c5a"]}},
    "tooltip": [{"field": "year", "type": "quantitative", "title": "Year", "format": "d"}, {"field": "fire_type", "type": "nominal", "title": "Type"}, {"field": "area_ha", "type": "quantitative", "title": "Area (ha)", "format": ","}]
  }
}
