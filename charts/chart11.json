{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Distribution of Victorian bushfire sizes, binned by hectares on a logarithmic scale of classes. Source: Historical Bushfire Boundaries v2.0 (Digital Atlas of Australia).",
  "title": {
    "text": "Most bushfires are small",
    "subtitle": "Number of bushfires by size class",
    "anchor": "start",
    "offset": 12,
    "fontSize": 21,
    "fontWeight": 700,
    "color": "#211c19",
    "font": "Spectral, Georgia, serif",
    "subtitleFontSize": 13,
    "subtitleColor": "#6b625a",
    "subtitleFont": "Inter, system-ui, sans-serif",
    "subtitleFontWeight": 500
  },
  "width": "container",
  "height": 400,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "font": "Inter, system-ui, sans-serif",
    "padding": 10,
    "axis": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 8,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "legend": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "symbolSize": 110
    },
    "view": {
      "stroke": null
    }
  },
  "layer": [
    {
      "data": {
        "url": "data/hist_size_hist.csv"
      },
      "transform": [
        {
          "filter": "datum.n_fires > 0"
        }
      ],
      "mark": {
        "type": "bar",
        "color": "#b34700"
      },
      "encoding": {
        "x": {
          "field": "size_class_ha",
          "type": "nominal",
          "title": "Fire size (hectares)",
          "sort": [
            "0–1",
            "1–10",
            "10–100",
            "100–1k",
            "1k–10k",
            "10k–100k",
            "100k+"
          ],
          "axis": {
            "labelAngle": -25,
            "labelFontSize": 13
          }
        },
        "y": {
          "field": "n_fires",
          "type": "quantitative",
          "title": "Number of bushfires",
          "scale": {
            "domain": [
              0,
              3200
            ]
          }
        },
        "tooltip": [
          {
            "field": "size_class_ha",
            "type": "nominal",
            "title": "Size (ha)"
          },
          {
            "field": "n_fires",
            "type": "quantitative",
            "title": "Bushfires"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "size_class_ha": "1–10",
            "n_fires": 2627,
            "n_label": 3000,
            "label": "Most fires burn ≤ 10 ha"
          },
          {
            "size_class_ha": "100k+",
            "n_fires": 53,
            "n_label": 2700,
            "label": "Only 53 reached 100,000+ ha"
          }
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#5a2600",
        "strokeWidth": 1,
        "strokeDash": [
          3,
          3
        ]
      },
      "encoding": {
        "x": {
          "field": "size_class_ha",
          "type": "nominal",
          "sort": [
            "0–1",
            "1–10",
            "10–100",
            "100–1k",
            "1k–10k",
            "10k–100k",
            "100k+"
          ]
        },
        "y": {
          "field": "n_fires",
          "type": "quantitative"
        },
        "y2": {
          "field": "n_label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "size_class_ha": "1–10",
            "n_label": 3000,
            "label": "Most common: 1–10 ha"
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Inter, system-ui, sans-serif",
        "fontStyle": "italic",
        "fontWeight": 700,
        "fontSize": 14,
        "color": "#3d1900",
        "dy": -8,
        "align": "left",
        "dx": -4
      },
      "encoding": {
        "x": {
          "field": "size_class_ha",
          "type": "nominal",
          "sort": [
            "0–1",
            "1–10",
            "10–100",
            "100–1k",
            "1k–10k",
            "10k–100k",
            "100k+"
          ]
        },
        "y": {
          "field": "n_label",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "size_class_ha": "100k+",
            "n_label": 2700,
            "label": "Only 53 reached 100,000+ ha"
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Inter, system-ui, sans-serif",
        "fontStyle": "italic",
        "fontWeight": 700,
        "fontSize": 14,
        "color": "#3d1900",
        "dy": -8,
        "align": "right",
        "dx": -6
      },
      "encoding": {
        "x": {
          "field": "size_class_ha",
          "type": "nominal",
          "sort": [
            "0–1",
            "1–10",
            "10–100",
            "100–1k",
            "1k–10k",
            "10k–100k",
            "100k+"
          ]
        },
        "y": {
          "field": "n_label",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ]
}