{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Area burnt per decade, split into bushfire and prescribed (planned) burning. Click a series in the legend to isolate it. Source: Historical Bushfire Boundaries v2.0 (Digital Atlas of Australia).",
  "title": {
    "text": "Area burnt by decade",
    "subtitle": "Bushfire vs planned (prescribed) burning",
    "anchor": "start",
    "offset": 12,
    "fontSize": 21,
    "fontWeight": 700,
    "color": "#211c19",
    "font": "Inter Tight, Inter, system-ui, sans-serif",
    "subtitleFontSize": 13,
    "subtitleColor": "#6b625a",
    "subtitleFont": "Inter, system-ui, sans-serif",
    "subtitleFontWeight": 500
  },
  "width": "container",
  "height": 360,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "font": "Inter, system-ui, sans-serif",
    "padding": 10,
    "axis": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 8,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "legend": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "symbolSize": 110
    },
    "view": {
      "stroke": null
    }
  },
  "layer": [
    {
      "data": {
        "url": "data/hist_decade_type.csv"
      },
      "mark": {
        "type": "bar"
      },
      "encoding": {
        "x": {
          "field": "decade",
          "type": "nominal",
          "title": null,
          "axis": {
            "labelAngle": 0
          }
        },
        "y": {
          "field": "area_ha",
          "type": "quantitative",
          "title": "Area burnt (ha)",
          "stack": "zero"
        },
        "color": {
          "field": "fire_type",
          "type": "nominal",
          "title": "Fire type",
          "scale": {
            "domain": [
              "Bushfire",
              "Prescribed Burn"
            ],
            "range": [
              "#b34700",
              "#5b8c5a"
            ]
          }
        },
        "opacity": {
          "condition": {
            "param": "fireSel",
            "value": 1
          },
          "value": 0.2
        },
        "tooltip": [
          {
            "field": "decade",
            "type": "nominal",
            "title": "Decade"
          },
          {
            "field": "fire_type",
            "type": "nominal",
            "title": "Type"
          },
          {
            "field": "area_ha",
            "type": "quantitative",
            "title": "Area (ha)",
            "format": ","
          }
        ]
      },
      "params": [
        {
          "name": "fireSel",
          "select": {
            "type": "point",
            "fields": [
              "fire_type"
            ]
          },
          "bind": "legend"
        }
      ]
    },
    {
      "data": {
        "values": [
          {
            "decade": "2000s",
            "area_ha": 14310000,
            "area_label": 16500000,
            "label": "Worst decade on record"
          }
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#5a2600",
        "strokeWidth": 1,
        "strokeDash": [
          3,
          3
        ]
      },
      "encoding": {
        "x": {
          "field": "decade",
          "type": "nominal"
        },
        "y": {
          "field": "area_ha",
          "type": "quantitative"
        },
        "y2": {
          "field": "area_label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "decade": "2000s",
            "area_label": 16500000,
            "label": "Worst decade on record"
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Inter, system-ui, sans-serif",
        "fontStyle": "italic",
        "fontWeight": 600,
        "fontSize": 14,
        "color": "#5a2600",
        "align": "center",
        "dy": -8
      },
      "encoding": {
        "x": {
          "field": "decade",
          "type": "nominal"
        },
        "y": {
          "field": "area_label",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ]
}