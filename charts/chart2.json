{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "At-risk education facilities by fire weather district. Source: BARR register (data.vic.gov.au).",
  "title": {
    "text": "At-risk facilities by fire weather district",
    "anchor": "start",
    "fontSize": 26,
    "font": "Newsreader, Source Serif 4, Georgia, serif",
    "fontWeight": 700,
    "color": "#211c19",
    "offset": 14
  },
  "width": "container",
  "height": 280,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "font": "Source Sans 3, sans-serif",
    "padding": 10,
    "axis": {
      "labelFontSize": 15,
      "titleFontSize": 16,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 12,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "legend": {
      "labelFontSize": 15,
      "titleFontSize": 16,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "symbolSize": 120
    },
    "view": {
      "stroke": null
    }
  },
  "data": {
    "url": "data/barr_by_district.csv"
  },
  "mark": {
    "type": "bar",
    "color": "#b34700"
  },
  "encoding": {
    "y": {
      "field": "district",
      "type": "nominal",
      "title": null,
      "sort": "-x"
    },
    "x": {
      "field": "n",
      "type": "quantitative",
      "title": "Facilities"
    },
    "tooltip": [
      {
        "field": "district",
        "type": "nominal",
        "title": "District"
      },
      {
        "field": "n",
        "type": "quantitative",
        "title": "Facilities"
      }
    ]
  }
}