{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "At-risk education facilities by fire weather district. Source: BARR register (data.vic.gov.au).",
  "title": {"text": "At-risk facilities by fire weather district", "anchor": "start", "fontSize": 15},
  "width": "container",
  "height": 280,
  "autosize": {"type": "fit", "contains": "padding"},
  "config": {"font": "Source Sans 3, sans-serif"},
  "data": {"url": "data/barr_by_district.csv"},
  "mark": {"type": "bar", "color": "#b34700"},
  "encoding": {
    "y": {"field": "district", "type": "nominal", "title": null, "sort": "-x"},
    "x": {"field": "n", "type": "quantitative", "title": "Facilities"},
    "tooltip": [{"field": "district", "type": "nominal", "title": "District"}, {"field": "n", "type": "quantitative", "title": "Facilities"}]
  }
}
