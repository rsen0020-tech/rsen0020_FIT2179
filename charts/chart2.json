{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "At-risk education facilities by fire weather district, with the Central district highlighted. Source: BARR register (data.vic.gov.au).",
  "title": {
    "text": "At-risk facilities by fire weather district",
    "anchor": "start",
    "offset": 12,
    "fontSize": 21,
    "fontWeight": 700,
    "color": "#211c19",
    "font": "Inter Tight, Inter, system-ui, sans-serif"
  },
  "width": "container",
  "height": 380,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "font": "Inter, system-ui, sans-serif",
    "padding": 10,
    "axis": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 8,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "legend": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "symbolSize": 110
    },
    "view": {
      "stroke": null
    }
  },
  "layer": [
    {
      "data": {
        "url": "data/barr_by_district.csv"
      },
      "mark": {
        "type": "bar",
        "color": "#b34700"
      },
      "encoding": {
        "y": {
          "field": "district",
          "type": "nominal",
          "title": null,
          "sort": [
            "Central",
            "Northern Country",
            "North East",
            "North Central",
            "South West",
            "West and South Gippsland",
            "East Gippsland",
            "Mallee",
            "Wimmera"
          ]
        },
        "x": {
          "field": "n",
          "type": "quantitative",
          "title": "Facilities"
        },
        "tooltip": [
          {
            "field": "district",
            "type": "nominal",
            "title": "District"
          },
          {
            "field": "n",
            "type": "quantitative",
            "title": "Facilities"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "district": "Central",
            "n": 473,
            "note": "More than half on its own"
          }
        ]
      },
      "mark": {
        "type": "text",
        "color": "#fff",
        "font": "Inter, system-ui, sans-serif",
        "fontStyle": "italic",
        "fontWeight": 600,
        "align": "right",
        "dx": -10,
        "fontSize": 14
      },
      "encoding": {
        "y": {
          "field": "district",
          "type": "nominal",
          "sort": [
            "Central",
            "Northern Country",
            "North East",
            "North Central",
            "South West",
            "West and South Gippsland",
            "East Gippsland",
            "Mallee",
            "Wimmera"
          ]
        },
        "x": {
          "field": "n",
          "type": "quantitative"
        },
        "text": {
          "field": "note",
          "type": "nominal"
        }
      }
    }
  ]
}