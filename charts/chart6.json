{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Stacked bar of risk categories within each education sector. Source: BARR register (data.vic.gov.au).",
  "title": {
    "text": "Risk categories by education sector",
    "anchor": "start",
    "fontSize": 26,
    "font": "Fraunces, Georgia, serif",
    "fontWeight": 700,
    "color": "#211c19",
    "offset": 14
  },
  "width": "container",
  "height": 340,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "font": "Inter, system-ui, sans-serif",
    "padding": 10,
    "axis": {
      "labelFontSize": 17,
      "titleFontSize": 18,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 12,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "legend": {
      "labelFontSize": 17,
      "titleFontSize": 18,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "symbolSize": 140
    },
    "view": {
      "stroke": null
    }
  },
  "data": {
    "url": "data/barr_sector_category.csv"
  },
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "y": {
      "field": "sector",
      "type": "nominal",
      "title": null,
      "sort": {
        "field": "n",
        "op": "sum",
        "order": "descending"
      }
    },
    "x": {
      "field": "n",
      "type": "quantitative",
      "title": "Facilities",
      "stack": "zero"
    },
    "color": {
      "field": "category",
      "type": "nominal",
      "title": "Risk category",
      "sort": [
        "CAT 0",
        "CAT 1",
        "CAT 2",
        "CAT 3"
      ],
      "scale": {
        "scheme": "oranges"
      }
    },
    "tooltip": [
      {
        "field": "sector",
        "type": "nominal",
        "title": "Sector"
      },
      {
        "field": "category",
        "type": "nominal",
        "title": "Category"
      },
      {
        "field": "n",
        "type": "quantitative",
        "title": "Facilities"
      }
    ]
  }
}