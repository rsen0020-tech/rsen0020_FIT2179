{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Heatmap of bushfire counts by month and decade, with the summer fire window called out. Source: Historical Bushfire Boundaries v2.0 (Digital Atlas of Australia).",
  "title": {
    "text": "Bushfire timing across the decades",
    "subtitle": "Number of bushfires by month",
    "anchor": "start",
    "offset": 12,
    "fontSize": 21,
    "fontWeight": 700,
    "color": "#211c19",
    "font": "Plus Jakarta Sans, Inter, system-ui, sans-serif",
    "subtitleFontSize": 13,
    "subtitleColor": "#6b625a",
    "subtitleFont": "Inter, system-ui, sans-serif",
    "subtitleFontWeight": 500
  },
  "width": "container",
  "height": 380,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "font": "Inter, system-ui, sans-serif",
    "padding": 10,
    "axis": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 8,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "legend": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "symbolSize": 110
    },
    "view": {
      "stroke": null
    }
  },
  "encoding": {
    "x": {
      "field": "month",
      "type": "nominal",
      "title": null,
      "sort": [
        "Jan",
        "Feb",
        "Mar",
        "Apr",
        "May",
        "Jun",
        "Jul",
        "Aug",
        "Sep",
        "Oct",
        "Nov",
        "Dec"
      ],
      "axis": {
        "labelAngle": 0,
        "labelFontSize": 13
      }
    },
    "y": {
      "field": "decade",
      "type": "nominal",
      "title": null,
      "axis": {
        "labelFontSize": 13
      }
    }
  },
  "layer": [
    {
      "data": {
        "url": "data/hist_decade_month_bushfire.csv"
      },
      "mark": {
        "type": "rect",
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "color": {
          "field": "n_bushfires",
          "type": "quantitative",
          "title": "Bushfires",
          "scale": {
            "scheme": "yelloworangered"
          }
        },
        "tooltip": [
          {
            "field": "decade",
            "type": "nominal",
            "title": "Decade"
          },
          {
            "field": "month",
            "type": "nominal",
            "title": "Month"
          },
          {
            "field": "n_bushfires",
            "type": "quantitative",
            "title": "Bushfires"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "month": "Mar",
            "decade": "2010s",
            "label": "← Jan–Feb bushfire peak"
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Inter, system-ui, sans-serif",
        "fontStyle": "italic",
        "fontWeight": 700,
        "fontSize": 14,
        "color": "#3d1900",
        "align": "left",
        "dx": 4,
        "dy": 0
      },
      "encoding": {
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ]
}