{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "The 15 largest individual Victorian bushfire footprints on record, with the 1939 Black Friday fire highlighted. Source: Historical Bushfire Boundaries v2.0 (Digital Atlas of Australia).",
  "title": {
    "text": "Largest single bushfires on record",
    "subtitle": "Single fire footprints, hectares — hover a bar for the year and total",
    "anchor": "start",
    "offset": 12,
    "fontSize": 21,
    "fontWeight": 700,
    "color": "#211c19",
    "font": "Spectral, Georgia, serif",
    "subtitleFontSize": 13,
    "subtitleColor": "#6b625a",
    "subtitleFont": "Inter, system-ui, sans-serif",
    "subtitleFontWeight": 500
  },
  "width": "container",
  "height": 380,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "font": "Inter, system-ui, sans-serif",
    "padding": 10,
    "axis": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 8,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "view": {
      "stroke": null
    }
  },
  "layer": [
    {
      "data": {
        "url": "data/hist_top_fires.csv"
      },
      "params": [
        {
          "name": "hover",
          "select": {
            "type": "point",
            "on": "pointerover",
            "clear": "pointerout",
            "fields": ["fire_name"]
          }
        }
      ],
      "mark": {
        "type": "bar",
        "color": "#b34700",
        "cornerRadiusEnd": 3
      },
      "encoding": {
        "y": {
          "field": "fire_name",
          "type": "nominal",
          "title": null,
          "sort": "-x",
          "axis": {
            "labelLimit": 180,
            "labelFontSize": 12,
            "labelPadding": 6
          }
        },
        "x": {
          "field": "area_ha",
          "type": "quantitative",
          "title": "Total area burnt (hectares)",
          "axis": {
            "format": "~s",
            "tickCount": 4,
            "grid": false,
            "ticks": false,
            "domainColor": "#c9c0b3"
          }
        },
        "fillOpacity": {
          "condition": {"param": "hover", "empty": false, "value": 1},
          "value": 0.85
        },
        "tooltip": [
          {"field": "fire_name", "type": "nominal", "title": "Fire"},
          {"field": "year", "type": "quantitative", "title": "Year", "format": "d"},
          {"field": "area_ha", "type": "quantitative", "title": "Total area (ha)", "format": ","}
        ]
      }
    },
    {
      "data": {
        "values": [
          {"fire_name": "Black Friday (1939)", "area_ha": 2384394, "note": "Largest on record"}
        ]
      },
      "mark": {
        "type": "text",
        "font": "Inter, system-ui, sans-serif",
        "fontStyle": "italic",
        "fontWeight": 700,
        "fontSize": 13,
        "color": "#ffffff",
        "align": "right",
        "dx": -12
      },
      "encoding": {
        "y": {"field": "fire_name", "type": "nominal", "sort": "-x"},
        "x": {"field": "area_ha", "type": "quantitative"},
        "text": {"field": "note", "type": "nominal"}
      }
    }
  ]
}
