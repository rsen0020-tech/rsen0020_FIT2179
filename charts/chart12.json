{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "The 15 largest individual Victorian bushfire footprints on record, with the 1939 Black Friday fires highlighted. Source: Historical Bushfire Boundaries v2.0 (Digital Atlas of Australia).",
  "title": {
    "text": "The largest recorded bushfires",
    "subtitle": "Single fire footprints, hectares",
    "anchor": "start",
    "offset": 14,
    "fontSize": 26,
    "fontWeight": 700,
    "color": "#211c19",
    "font": "Newsreader, Source Serif 4, Georgia, serif",
    "subtitleFontSize": 17,
    "subtitleColor": "#6b625a",
    "subtitleFont": "Source Sans 3, sans-serif",
    "subtitleFontStyle": "italic"
  },
  "width": "container",
  "height": 420,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "font": "Source Sans 3, sans-serif",
    "padding": 10,
    "axis": {
      "labelFontSize": 15,
      "titleFontSize": 16,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 12,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "legend": {
      "labelFontSize": 15,
      "titleFontSize": 16,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "symbolSize": 120
    },
    "view": {
      "stroke": null
    }
  },
  "layer": [
    {
      "data": {
        "url": "data/hist_top_fires.csv"
      },
      "transform": [
        {
          "calculate": "datum.fire_name + ' (' + datum.year + ')'",
          "as": "label"
        }
      ],
      "params": [
        {
          "name": "hover",
          "select": {
            "type": "point",
            "on": "pointerover",
            "clear": "pointerout"
          }
        }
      ],
      "mark": {
        "type": "bar",
        "color": "#b34700"
      },
      "encoding": {
        "y": {
          "field": "label",
          "type": "nominal",
          "title": null,
          "sort": "-x"
        },
        "x": {
          "field": "area_ha",
          "type": "quantitative",
          "title": "Area burnt (ha)"
        },
        "fillOpacity": {
          "condition": {
            "param": "hover",
            "empty": false,
            "value": 1
          },
          "value": 0.85
        },
        "tooltip": [
          {
            "field": "fire_name",
            "type": "nominal",
            "title": "Fire"
          },
          {
            "field": "year",
            "type": "quantitative",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "area_ha",
            "type": "quantitative",
            "title": "Area (ha)",
            "format": ","
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "label": "(unnamed) (1939)",
            "area_ha": 2384394,
            "note": "Black Friday, 1939"
          }
        ]
      },
      "mark": {
        "type": "text",
        "fontWeight": "bold",
        "fontSize": 13,
        "color": "#fff",
        "align": "right",
        "dx": -8
      },
      "encoding": {
        "y": {
          "field": "label",
          "type": "nominal",
          "sort": "-x"
        },
        "x": {
          "field": "area_ha",
          "type": "quantitative"
        },
        "text": {
          "field": "note",
          "type": "nominal"
        }
      }
    }
  ]
}