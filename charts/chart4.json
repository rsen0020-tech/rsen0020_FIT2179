{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Number of at-risk facilities in each BARR bushfire risk category, with the highest-risk Category 1 tier called out. Source: BARR register (data.vic.gov.au).",
  "title": {
    "text": "Facilities by bushfire risk category",
    "subtitle": "Risk tiers assigned in the register; Category 1 facilities face the highest risk",
    "anchor": "start",
    "fontSize": 21,
    "subtitleColor": "#6b625a",
    "subtitleFontSize": 13,
    "font": "Spectral, Georgia, serif",
    "fontWeight": 700,
    "color": "#211c19",
    "subtitleFont": "Inter, system-ui, sans-serif",
    "subtitleFontWeight": 500,
    "offset": 12
  },
  "width": "container",
  "height": 340,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "font": "Inter, system-ui, sans-serif",
    "padding": 10,
    "axis": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "titlePadding": 8,
      "domainColor": "#c9c0b3",
      "tickColor": "#c9c0b3",
      "gridColor": "#eee8dc"
    },
    "legend": {
      "labelFontSize": 13,
      "titleFontSize": 14,
      "titleColor": "#211c19",
      "labelColor": "#211c19",
      "titleFontWeight": 600,
      "symbolSize": 110
    },
    "view": {
      "stroke": null
    }
  },
  "data": {
    "url": "data/barr_by_category.csv"
  },
  "encoding": {
    "x": {
      "field": "category",
      "type": "nominal",
      "title": null,
      "sort": [
        "CAT 0",
        "CAT 1",
        "CAT 2",
        "CAT 3"
      ],
      "axis": {
        "labelAngle": 0,
        "labelFontSize": 13,
        "labelFontWeight": 600
      }
    },
    "y": {
      "field": "n",
      "type": "quantitative",
      "title": "Facilities"
    }
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "color": "#b34700"
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": -6,
        "fontSize": 13,
        "fontWeight": 700,
        "color": "#2b2b2b"
      },
      "encoding": {
        "text": {
          "field": "n",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "category": "CAT 1",
            "n": 24,
            "n_label": 230,
            "note": "Must close on Code Red days"
          }
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#5a2600",
        "strokeWidth": 1,
        "strokeDash": [
          3,
          3
        ]
      },
      "encoding": {
        "y": {
          "field": "n",
          "type": "quantitative"
        },
        "y2": {
          "field": "n_label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "category": "CAT 1",
            "n_label": 230,
            "note": "Must close on Code Red days"
          }
        ]
      },
      "mark": {
        "type": "text",
        "dy": -8,
        "fontSize": 14,
        "font": "Inter, system-ui, sans-serif",
        "fontStyle": "italic",
        "fontWeight": 700,
        "color": "#3d1900",
        "align": "center"
      },
      "encoding": {
        "y": {
          "field": "n_label",
          "type": "quantitative"
        },
        "text": {
          "field": "note",
          "type": "nominal"
        }
      }
    }
  ]
}